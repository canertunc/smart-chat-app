@using Microsoft.EntityFrameworkCore.Metadata.Internal
@model List<Order>

<div class="container mt-5 mb-5">
    <h4 class="text-success text-center mb-4">Orders Table</h4>
    <div>

        <a asp-controller="Database" asp-action="SendOrder"><button type="submit" class="btn btn-primary mb-2"
                style="width: 140px; font-size: 12px">Add Order</button></a>

    </div>
    <div class="table-responsive shadow-sm rounded">
        <table id="database_table" class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Delete Order</th>
                    <th>Order Id</th>
                    <th>Customer Id</th>
                    <th>Employee Id</th>
                    <th>Order Date</th>
                    <th>Required Date</th>
                    <th>Shipped Date</th>
                    <th>Ship Via</th>
                    <th>Freight</th>
                    <th>Ship Name</th>
                    <th>Ship Address</th>
                    <th>Ship City</th>
                    <th>Ship Region</th>
                    <th>Ship PostalCode</th>
                    <th>Ship Country</th>
                </tr>
            </thead>
            <tbody>
                @foreach (Order order in Model)
                {
                    <tr>
                        <td>
                            <form action="/Database/DeleteOrder" method="POST">
                                <input type="hidden" name="orderId" value="@order.OrderId" />
                                <button type="submit" class="btn btn-danger">Delete</button>
                            </form>
                        </td>
                        <td>@order.OrderId</td>
                        <td>@order.CustomerId</td>
                        <td>@order.EmployeeId</td>
                        <td>@order.OrderDate?.ToString("yyyy-MM-dd")</td>
                        <td>@order.RequiredDate?.ToString("yyyy-MM-dd")</td>
                        <td>@order.ShippedDate?.ToString("yyyy-MM-dd")</td>
                        <td>@order.ShipVia</td>
                        <td>@order.Freight</td>
                        <td>@order.ShipName</td>
                        <td>@order.ShipAddress</td>
                        <td>@order.ShipCity</td>
                        <td>@order.ShipRegion</td>
                        <td>@order.ShipPostalCode</td>
                        <td>@order.ShipCountry</td>
                    </tr>
                }
            </tbody>
            <tfoot class="table-light">
                <tr>
                    <th>Delete Order</th>
                    <th>Order Id</th>
                    <th>Customer Id</th>
                    <th>Employee Id</th>
                    <th>Order Date</th>
                    <th>Required Date</th>
                    <th>Shipped Date</th>
                    <th>Ship Via</th>
                    <th>Freight</th>
                    <th>Ship Name</th>
                    <th>Ship Address</th>
                    <th>Ship City</th>
                    <th>Ship Region</th>
                    <th>Ship PostalCode</th>
                    <th>Ship Country</th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

<style>
    .table-responsive {
        max-height: 500px;
        overflow-y: auto;
        margin-bottom: 100px;
    }

    #database_table tbody tr:hover {
        background-color: #d1f0d1;
    }

    #database_table th,
    #database_table td {
        white-space: nowrap;
    }
</style>
