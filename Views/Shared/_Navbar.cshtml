@{
  var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
  var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<nav class="navbar navbar-expand-lg bg-body-tertiary">
  <div class="container-fluid">
    <a class="navbar-brand" href="/home"><i class="fa-solid fa-dragon fa-xl " style="color: #1d308b;"></i> RAG-Based
      Chatbot</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarText"
      aria-controls="navbarText" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarText">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item @(currentController == "Home" && currentAction == "Index" ? "active" : "")">
          <a class="nav-link" aria-current="page" asp-controller="Home" asp-action="Index"><i
              class="fa-regular fa-house"></i>Home</a>
        </li>
        <li class="nav-item @(currentController == "Chat" && currentAction == "Index" ? "active" : "")">
          <a class="nav-link" aria-current="page" asp-controller="Chat" asp-action="Index"><i
              class="fa-regular fa-comments"></i>Chat</a>
        </li>
        <li class="nav-item @(currentController == "Chatdb" && currentAction == "Index" ? "active" : "")">
          <a class="nav-link" aria-current="page" asp-controller="Chatdb" asp-action="Index"><i
              class="fa-solid fa-database"></i>Chat Database</a>
        </li>
        <li class="nav-item @(currentController == "Database" && currentAction == "Index" ? "active" : "")">
          <a class="nav-link" aria-current="page" asp-controller="Database" asp-action="Index"><i
              class="fa-solid fa-database"></i>Northwind Database</a>
        </li>
      </ul>
      <span class="navbar-text">
        <i class="fa-solid fa-user-tie"></i> Caner Tunç
      </span>
    </div>
  </div>
</nav>